window-rule {
    geometry-corner-radius 12 // Set every window radius to 20
    clip-to-geometry true
}

window-rule {
    match app-id="mpv"
    open-floating true
}

window-rule {
    match app-id="xdg-desktop-portal-gtk"
    open-floating true
    default-column-width {
        fixed 720
    }
}

layer-rule {
    match namespace="^noctalia-wallpaper*"
    place-within-backdrop true
}
